# Rename this file to .env and place your API keys here

# For Google Gemini (Default configuration)
GEMINI_API_KEY=your_gemini_api_key_here

# For OpenAI (If you change model_name="gpt-4o" etc.)
OPENAI_API_KEY=your_openai_api_key_here

# For Anthropic (If you change model_name="claude-3-5-sonnet-20240620" etc.)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
